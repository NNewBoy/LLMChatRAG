# ========================================
# 服务器配置
# ========================================
HOST=0.0.0.0
PORT=8000

# ========================================
# LLM 模型配置 (Agent 和 RAG 共用)
# ========================================
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_API_BASE_URL=https://api.deepseek.com/v1

# ========================================
# SQLite 数据库路径
# ========================================
SQLITE_DB_PATH=./data/sqlite/chatrag.db
BAD_CASE_DB_PATH=

# ========================================
# Embedding 模型配置 (RAG 向量化)
# ========================================
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_API_KEY=sk-xxxxxxxx
EMBEDDING_API_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_PROVIDER=siliconflow

# ========================================
# RAG 数据库路径
# ========================================
FAISS_DB_PATH=./data/faiss/

# ========================================
# RAG 功能开关 (默认值，前端可运行时覆盖)
# ========================================
ENABLE_QUERY_REWRITING=true
ENABLE_HYBRID_SEARCH=false
ENABLE_RERANKING=false

# ========================================
# 混合检索参数
# ========================================
HYBRID_ALPHA=0.7
HYBRID_BETA=0.3

# ========================================
# RAG 检索参数
# ========================================
RAG_TOP_K=10
RAG_TOP_N=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# ========================================
# 联网搜索配置
# ========================================
SEARCH_API_KEY=
SEARCH_API_URL=

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
